---
import '../styles/global.css';
---
<body class="bg-[#86a67a] text-[#3d5143] font-sans min-h-screen overflow-x-hidden">
  
  <nav class="flex justify-between items-center px-12 py-8 relative z-10">
    <div class="flex gap-8 font-bold text-sm uppercase tracking-wide">
      <a href="#" class="hover:opacity-70">Sobre el proyecto</a>
      <a href="#" class="hover:opacity-70">Objetivos</a>
      <a href="#" class="hover:opacity-70">Investigacion</a>
      <a href="#" class="hover:opacity-70">Futuro</a>
      <a href="#" class="hover:opacity-70">Contactanos</a>
    </div>
    <div class="w-16 h-16 bg-[#3d5143]/20 rounded-full flex items-center justify-center border border-white/30">
       <span class="text-[8px] text-center leading-tight text-white font-bold">BREATHE<br/>RESPIRAR</span>
    </div>
  </nav>

  <main class="relative flex flex-col justify-center min-h-[80vh] px-12 lg:px-32">
    
    <img 
      src="../assets/enredadera.jpg" 
      alt="Ivy" 
      class="absolute left-0 top-0 h-full object-cover pointer-events-none select-none"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      
      <section class="max-w-xl z-10">
        <h1 class="text-6xl md:text-7xl font-black uppercase leading-[0.9] mb-6 tracking-tighter">
          Breathe / <br/> <span class="opacity-80">Respirar</span>
        </h1>
        <p class="text-lg leading-relaxed font-medium max-w-md">
          Breathe/Respirar es un programa multidisciplinario de investigación en acción, 
          que estudia cómo la infraestructura verde y otras soluciones basadas en la naturaleza 
          contribuyen a la calidad del aire, a la salud, y al bienestar.
        </p>
      </section>

      <section class="relative h-[400px] flex gap-4 items-center justify-center">
        <div class="w-24 h-80 rounded-full overflow-hidden shadow-xl">
           <img src="/hero-image.png" class="h-full w-full object-cover" />
        </div>
      </section>

    </div>

    <div class="absolute bottom-10 left-0 w-full px-12">
        <div class="h-[1px] bg-yellow-200/50 w-full"></div>
    </div>
  </main>

</body>