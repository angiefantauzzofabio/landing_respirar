---
import '../styles/global.css';
---
<body class="bg-[#86a67a] text-[#485749] font-sans min-h-screen overflow-x-hidden">
  
	<img 
		src="/enredadera.png" 
		alt="Enredadera cayendo"
		class="hidden md:block fixed left-0 top-0 h-[110vh] w-auto object-cover object-top pointer-events-none select-none z-30 py-0 px-0"
	/>
  
	<nav class="relative z-30 flex justify-between md:justify-end items-center px-8 md:px-12 py-8 w-full">
    
		<button id="menu-btn" class="block md:hidden focus:outline-none z-50">
		  <div class="w-6 h-0.5 bg-[#3d5143] mb-1.5 transition-all"></div>
		  <div class="w-6 h-0.5 bg-[#3d5143] mb-1.5 transition-all"></div>
		  <div class="w-6 h-0.5 bg-[#3d5143] transition-all"></div>
		</button>
	
		<div id="menu-links" class="fixed inset-0 bg-[#86a67a] flex-col items-center justify-center gap-8 text-xl font-bold uppercase tracking-widest transition-transform transform translate-x-full md:relative md:inset-auto md:flex md:flex-row md:translate-x-0 md:bg-transparent md:text-sm md:gap-8 md:tracking-wide hidden">
		  <a href="#" class="hover:opacity-70">Sobre el proyecto</a>
		  <a href="#" class="hover:opacity-70">Objetivos</a>
		  <a href="#" class="hover:opacity-70">Investigación</a>
		  <a href="#" class="hover:opacity-70">Futuro</a>
		  <a href="#" class="hover:opacity-70">Contáctanos</a>
		</div>
	</nav>

	<main class="relative z-10 flex items-center justify-center min-h-[calc(100vh-100px)] px-8 md:px-12 lg:px-40 pb-20">

	  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center w-full max-w-4xl mx-auto">
		
		<section class="max-w-5xl text-center md:text-left order-1">
		  <h1 class="text-5xl md:text-7xl font-black uppercase leading-[0.9] mb-6 tracking-tighter">
			Breathe / <br/> <span class="opacity-80">Respirar</span>
		  </h1>
		  <p class="text-base md:text-lg leading-relaxed font-medium mx-auto md:mx-0 max-w-md">
			Breathe/Respirar es un programa multidisciplinario de investigación en acción, 
			que estudia cómo la infraestructura verde y otras soluciones basadas en la naturaleza 
			contribuyen a la calidad del aire, a la salud, y al bienestar.
		  </p>
		</section>
  
		<section class="flex items-center justify-center order-2">
		  <div class="w-full max-w-[280px] md:max-w-sm">
			  <img src="/hero-image.png" class="w-full h-auto object-cover rounded-3xl" />
		  </div>
		</section>
  
	  </div>
	</main>
  
	<div class="fixed left-0 w-full px-0 z-10 pointer-events-none">
		<div class="h-[5px] bg-[#E2F774]/80 w-full"></div>
	</div>

	<script>
		// Añadimos "as HTMLElement" si usas TypeScript puro, 
		// o simplemente usamos el chequeo de seguridad:
		const btn = document.getElementById('menu-btn');
		const menu = document.getElementById('menu-links');
	  
		if (btn && menu) {
		  btn.addEventListener('click', () => {
			// Toggle de visibilidad
			menu.classList.toggle('hidden');
			menu.classList.toggle('flex');
			
			// Pequeño delay para que la transición de CSS funcione
			setTimeout(() => {
			  menu.classList.toggle('translate-x-full');
			}, 10);
		  });
		}
	</script>
  
  </body>