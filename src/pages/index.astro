---
import '../styles/global.css';
---
<body class="bg-[#86a67a] text-[#3d5143] font-sans min-h-screen overflow-x-hidden">
  
	<img 
	  src="/enredadera.png" 
	  alt="Ivy" 
	  class="fixed left-0 top-0 h-full w-auto object-cover pointer-events-none select-none z-0"
	/>
  
	<nav class="relative z-10 flex justify-end px-12 py-8 w-full">
	  <div class="flex gap-8 font-bold text-sm uppercase tracking-wide">
		<a href="#" class="hover:opacity-70">Sobre el proyecto</a>
		<a href="#" class="hover:opacity-70">Objetivos</a>
		<a href="#" class="hover:opacity-70">Investigacion</a>
		<a href="#" class="hover:opacity-70">Futuro</a>
		<a href="#" class="hover:opacity-70">Contactanos</a>
	  </div>
	</nav>
  
	<main class="relative z-10 flex items-center justify-center min-h-[calc(100vh-100px)] px-12 lg:px-40">
	  
	  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center w-full">
		
		<section class="max-w-xl">
		  <h1 class="text-6xl md:text-7xl font-black uppercase leading-[0.9] mb-6 tracking-tighter">
			Breathe / <br/> <span class="opacity-80">Respirar</span>
		  </h1>
		  <p class="text-lg leading-relaxed font-medium max-w-md">
			Breathe/Respirar es un programa multidisciplinario de investigación en acción, 
			que estudia cómo la infraestructura verde y otras soluciones basadas en la naturaleza 
			contribuyen a la calidad del aire, a la salud, y al bienestar.
		  </p>
		</section>
  
		<section class="flex items-center justify-center">
		  <div class="w-full max-w-sm">
			  <img src="/hero-image.png" class="w-full h-auto object-cover rounded-3xl" />
		  </div>
		</section>
  
	  </div>
	</main>
  
	<div class="fixed bottom-10 left-0 w-full px-12 z-10 pointer-events-none">
		<div class="h-[1px] bg-yellow-200/50 w-full"></div>
	</div>
  
  </body>